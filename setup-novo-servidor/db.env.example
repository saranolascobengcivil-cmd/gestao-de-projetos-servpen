# Credenciais do PostgreSQL pro app "Gestão de Projetos SERVPEN".
#
# COPIE este arquivo pra /etc/gestao-de-projetos/db.env e edite a senha.
# O systemd (gestao-de-projetos.service) carrega esse arquivo via EnvironmentFile.
#
# Permissões obrigatórias após criar o arquivo real:
#   sudo mkdir -p /etc/gestao-de-projetos
#   sudo cp setup-novo-servidor/db.env.example /etc/gestao-de-projetos/db.env
#   sudo chown root:www-data /etc/gestao-de-projetos/db.env
#   sudo chmod 0640 /etc/gestao-de-projetos/db.env
#
# Forma simples (variáveis individuais):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestao_servpen
DB_USER=gestao_servpen
DB_PASSWORD=TROQUE_ESTA_SENHA

# Forma alternativa (URI única). Se setada, sobrepõe as variáveis acima.
# DATABASE_URL=postgresql://gestao_servpen:senha@localhost:5432/gestao_servpen
